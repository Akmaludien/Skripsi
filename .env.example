# ============================================================
# STMKG Monitoring System - Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
# ============================================================

# ─── InfluxDB Configuration ───────────────────────────────
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=your-influxdb-token-here
INFLUX_ORG=SKRIPSI
INFLUX_BUCKET=skripsi
INFLUX_TIMEOUT=60000

# ─── BMKG MQTT Configuration ─────────────────────────────
MQTT_BROKER=mqtt://202.90.198.159:1883
MQTT_USER=bmkg_aws
MQTT_PASS=your-mqtt-password-here

# ─── Python Command ───────────────────────────────────────
# Path to Python interpreter with TensorFlow installed
# Examples:
#   Local:  python3
#   Docker: /app/venv/bin/python3
#   Venv:   .venv/bin/python
PYTHON_CMD=python3

# ─── API Security ─────────────────────────────────────────
# API key for protecting write/admin endpoints (e.g. POST /api/stations/:id/command)
# Set to empty string to disable auth (dev only)
API_KEY=your-api-key-here

# ─── Server Configuration ─────────────────────────────────
PORT=3001
NODE_ENV=development
